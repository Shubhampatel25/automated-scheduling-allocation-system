# Git
.git
.github
.gitignore

# Environment files — secrets must never be baked into the image
.env
.env.*
!.env.example

# Vendor — reinstalled inside the image via composer install
vendor/
node_modules/

# Laravel runtime artefacts — regenerated fresh on each container boot
storage/logs/*
storage/framework/cache/data/*
storage/framework/sessions/*
storage/framework/views/*
bootstrap/cache/*.php

# Test / dev artefacts
tests/
phpunit.xml
.php-cs-fixer.cache

# Misc
*.log
*.md
.editorconfig
dat/

# NOTE: docker/ is intentionally NOT excluded.
# The Dockerfile relies on COPY . . to include docker/start.sh,
# docker/nginx.conf.template, and docker/supervisord.conf inside the image.
