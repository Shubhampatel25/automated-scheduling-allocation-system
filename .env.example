APP_NAME=Laravel
# Railway: set to "production" and APP_DEBUG to "false"
APP_ENV=local
# Railway: generate once with "php artisan key:generate --show" and paste here
APP_KEY=base64:u3pguUi1o5Mq3b61WYFDTXXxxpL+1b4l2NOwiuVMu6w=
APP_DEBUG=true
# Railway: set to your Railway public URL, e.g. https://your-app.up.railway.app
APP_URL=http://127.0.0.1:8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
# Railway MySQL plugin sets these automatically; copy values from Railway dashboard
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=scheduling_system
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
# Railway: containers are ephemeral — use "database" so sessions survive restarts
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

STRIPE_KEY=your_stripe_publishable_key_here
STRIPE_SECRET=your_stripe_secret_key_here

# ── Railway-specific production overrides ─────────────────────────────────────
# Set all variables below in the Railway dashboard under Variables.
# Do NOT commit real values here.
#
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=https://your-app.up.railway.app
# SESSION_DRIVER=database
# LOG_CHANNEL=stderr
# LOG_LEVEL=error